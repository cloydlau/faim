{
  "name": "faim",
  "PascalCasedName": "Faim",
  "type": "commonjs",
  "version": "0.14.0",
  "private": false,
  "description": "Element Plus & Element UI isomorphic UI component library, more than Element.",
  "author": {
    "name": "Cloyd Lau",
    "url": "https://github.com/cloydlau"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cloydlau/faim.git"
  },
  "keywords": [
    "crop",
    "cropper",
    "el-upload",
    "filepond",
    "offline",
    "qrcode",
    "qr code",
    "richtext",
    "rich text",
    "tinymce",
    "upload",
    "uploader",
    "viewer",
    "WYSIWYG"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./*": "./*"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "unpkg": "./dist/index.mjs",
  "jsdelivr": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "auto-import-resolver.ts",
    "dist",
    "docs",
    "scripts"
  ],
  "scripts": {
    "dev": "esno ./scripts/dev.mts",
    "update": "esno ./scripts/update.mjs",
    "check:dependencies": "node ./scripts/check-dependencies.mjs",
    "build": "npx unbuild && pnpm build:demo",
    "build:demo": "node ./scripts/build-demo.mjs",
    "preview": "vite preview",
    "release": "esno ./scripts/release.mjs",
    "lint": "eslint \"**/*.{js,mjs,cjs,jsx,ts,mts,cts,tsx,vue,json,md,html,css,scss,sass}\"",
    "lint:fix": "eslint \"**/*.{js,mjs,cjs,jsx,ts,mts,cts,tsx,vue,json,md,html,css,scss,sass}\" --fix",
    "lint:inspect": "pnpm exec eslint-config-inspector",
    "preinstall": "node -e \"if (process.env.INIT_CWD === process.cwd()) { process.exit(1) }\" || (pnpm dlx only-allow pnpm && pnpm config set registry https://registry.npmmirror.com)",
    "postinstall": "node -e \"if (process.env.INIT_CWD === process.cwd()) { process.exit(1) }\" || (pnpm exec simple-git-hooks && git config core.hooksPath .git/hooks/)"
  },
  "peerDependencies": {
    "element-plus": ">=2",
    "vue": "2||3"
  },
  "peerDependenciesMeta": {
    "element-plus": {
      "optional": true
    },
    "vue": {
      "optional": true
    }
  },
  "dependencies": {
    "@vueuse/core": "14.3.0",
    "await-to-js": "^3.0.0",
    "cropperjs": "^1.6.2",
    "cross-spawn": "^7.0.6",
    "del": "^8.0.1",
    "destr": "^2.0.5",
    "filepond": "^4.32.12",
    "filepond-plugin-file-validate-size": "^2.2.8",
    "filepond-plugin-file-validate-type": "^1.2.9",
    "filepond-plugin-image-validate-size": "^1.2.7",
    "kolorist": "^1.8.0",
    "lodash-es": "^4.18.1",
    "mime": "^4.1.0",
    "qrcode": "^1.5.4",
    "sass": "^1.101.0",
    "sortablejs": "^1.15.7",
    "sweetalert2": "^11.26.25",
    "swiper": "^12.2.0",
    "tinymce": "^6.8.6",
    "upng-js": "^2.1.0",
    "uuid": "^14.0.1",
    "validator": "^13.15.35",
    "viewerjs": "^1.11.7",
    "vue-demi": "^0.14.10",
    "vue-global-config": "^0.6.3"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.1.0",
    "@arethetypeswrong/cli": "^0.18.5",
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@element-plus/icons-vue": "2.3.2",
    "@eslint/config-inspector": "3.0.4",
    "@eslint/eslintrc": "^3.3.6",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^26.1.1",
    "@types/validator": "^13.15.10",
    "@vitejs/plugin-legacy": "^8.2.0",
    "@vitejs/plugin-vue": "6.0.7",
    "@vue/compiler-sfc": "3.5.39",
    "@vue/test-utils": "2.4.11",
    "ansis": "^4.3.1",
    "axios": "^1.18.1",
    "axios-shortcut": "^0.1.4",
    "browserslist": "^4.28.6",
    "browserslist-to-esbuild": "^2.1.1",
    "case-police": "^2.2.1",
    "cnpm": "^9.4.0",
    "code-inspector-plugin": "^2.0.1",
    "dayjs": "^1.11.21",
    "element-plus": "^2.14.3",
    "eslint": "^10.7.0",
    "eslint-plugin-financial": "^0.1.0",
    "eslint-plugin-format": "^2.0.1",
    "eslint-plugin-no-unsanitized": "^4.1.5",
    "esno": "^4.8.0",
    "faim": "workspace:*",
    "hash-wasm": "^4.12.0",
    "json-editor-vue": "^0.18.1",
    "license-checker": "^25.0.1",
    "lint-staged": "^17.0.8",
    "magicast": "^0.5.3",
    "mammoth": "^1.12.0",
    "npm-check-updates": "^22.2.9",
    "npm-deprecated-check": "^2.1.1",
    "only-allow": "^1.2.2",
    "prompts": "^2.4.2",
    "publint": "^0.3.21",
    "semver": "^7.8.5",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^5.9.3",
    "unbuild": "^3.6.1",
    "unocss": "66.7.5",
    "unplugin-unused": "^0.5.7",
    "vite": "^8.1.4",
    "vue": "^3.5.39",
    "vue-tsc": "3.3.7",
    "zhlint": "^0.8.2"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm check:dependencies && pnpm exec lint-staged",
    "commit-msg": "pnpm exec commitlint --edit ${1}"
  },
  "lint-staged": {
    "*.md": [
      "case-police --fix",
      "zhlint --fix"
    ],
    "*.{js,mjs,cjs,jsx,ts,mts,cts,tsx,vue,json,md,html,css,scss,sass}": "eslint --cache --fix"
  },
  "browserslist": [
    "last 6 years",
    "last 2 major versions",
    "not dead",
    "> 0.2%",
    "chrome >= 87",
    "firefox >= 78",
    "firefox esr",
    "safari >= 14",
    "edge >= 88",
    "ios >= 12",
    "android >= 9"
  ]
}
